{
  "name": "tientool-gunny2017",
  "productName": "Tientool-QLTK 2017",
  "version": "1.0.18",
  "description": "Tientool-QLTK 2017",
  "main": ".vite/build/main.js",
  "build": {
    "appId": "com.tientool.gunny",
    "productName": "Tientool-QLTK 2017",
    "publish": [
      {
        "provider": "github",
        "owner": "pmt1506",
        "repo": "TienTool",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "src/resources/clickermann",
        "to": "clickermann"
      }
    ],
    "asar": true,
    "files": [
      "dist/**",
      ".vite/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "private": true,
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electronmon .\"",
    "build": "vite build -c vite.main.config.mjs && vite build -c vite.preload.config.mjs && vite build -c vite.renderer.config.mjs",
    "dist": "npm run build && electron-builder --publish=always",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "pmt1506",
    "email": "pmtien150603@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "koffi": "^2.16.0",
    "lucide": "^1.8.0",
    "mongodb": "^7.1.1"
  }
}
