{
  "name": "tientool-gunny2017",
  "productName": "Tientool-QLTK 2017",
  "version": "1.0.1",
  "description": "Tientool-QLTK 2017",
  "main": ".vite/build/main.js",
  "build": {
    "appId": "com.tientool.gunny",
    "productName": "Tientool-QLTK 2017",
    "publish": [
      {
        "provider": "github",
        "owner": "pmt1506",
        "repo": "TienTool"
      }
    ],
    "asar": true,
    "files": [
      "dist/**",
      ".vite/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "vite build -c vite.main.config.mjs && vite build -c vite.preload.config.mjs && vite build -c vite.renderer.config.mjs",
    "dist": "npm run build && electron-builder",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "pmt1506",
    "email": "pmtien150603@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "autoprefixer": "^10.5.0",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "koffi": "^2.16.0",
    "lucide": "^1.8.0",
    "mongodb": "^7.1.1"
  }
}